<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="l|91h7BgTz2I0jTnL!lB" x="20" y="20"><statement name="HANDLER"><block type="typescript_statement" id="7}+9mS#UH@%tI;|a`Hak"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace CBurgController {" line1="" line2="    pins.setPull(DigitalPin.P0, PinPullMode.PullUp)" line3="    pins.setPull(DigitalPin.P1, PinPullMode.PullUp)" line4="    pins.setPull(DigitalPin.P8, PinPullMode.PullUp)" line5="    pins.setPull(DigitalPin.P9, PinPullMode.PullUp)" line6="    pins.setPull(DigitalPin.P2, PinPullMode.PullUp)" line7="    pins.setPull(DigitalPin.P12, PinPullMode.PullUp)" line8="    pins.setPull(DigitalPin.P13, PinPullMode.PullUp)" line9="    pins.setPull(DigitalPin.P14, PinPullMode.PullUp)" line10="    pins.setPull(DigitalPin.P15, PinPullMode.PullUp)" line11="    pins.setPull(DigitalPin.P16, PinPullMode.PullUp)" line12="    pins.setPull(DigitalPin.P19, PinPullMode.PullUp)" line13="    pins.setPull(DigitalPin.P20, PinPullMode.PullUp)" line14="" line15="    export enum Button {" line16="        //% block=&quot;black-up&quot;" line17="        //% block.loc.nl=&quot;zwart-omhoog&quot;" line18="        Button1, //P13" line19="        //% block=&quot;black-down&quot;" line20="        //% block.loc.nl=&quot;zwart-omlaag&quot;" line21="        Button2, //P15 " line22="        //% block=&quot;black-left&quot;" line23="        //% block.loc.nl=&quot;zwart-links&quot;" line24="        Button3, //P1" line25="        //% block=&quot;black-right&quot;" line26="        //% block.loc.nl=&quot;zwart-rechts&quot;" line27="        Button4, //P9" line28="        //% block=&quot;red-up&quot;" line29="        //% block.loc.nl=&quot;rood-omhoog&quot;" line30="        Button5, //p16" line31="        //% block=&quot;red-down&quot;" line32="        //% block.loc.nl=&quot;rood-omlaag&quot;" line33="        Button6, //P2" line34="        //% block=&quot;red-left&quot;" line35="        //% block.loc.nl=&quot;rood-links&quot;" line36="        Button7, //P19" line37="        //% block=&quot;red-right&quot;" line38="        //% block.loc.nl=&quot;rood-rechts&quot;" line39="        Button8, //P14" line40="        //% block=&quot;blue-left&quot;" line41="        //% block.loc.nl=&quot;blauw-links&quot;" line42="        Button9, //P20" line43="        //% block=&quot;blue-right&quot;" line44="        //% block.loc.nl=&quot;blauw-rechts&quot;" line45="        Button10, //P12" line46="        //% block=&quot;yellow-left&quot;" line47="        //% block.loc.nl=&quot;geel-links&quot;" line48="        Button11, //P0" line49="        //% block=&quot;yellow-right&quot;" line50="        //% block.loc.nl=&quot;geel-rechts&quot;" line51="        Button12 //P8" line52="    }" line53="" line54="    //% block=&quot;pin $button&quot;" line55="    //% block.loc.nl=&quot;pin %button&quot;" line56="    export function buttonPin(button: Button) : number {" line57="        let pin = 0;" line58="        switch (button) {" line59="            case Button.Button1: pin = DigitalPin.P13; break;" line60="            case Button.Button2: pin = DigitalPin.P15; break;" line61="            case Button.Button3: pin = DigitalPin.P1; break;" line62="            case Button.Button4: pin = DigitalPin.P9; break;" line63="            case Button.Button5: pin = DigitalPin.P16; break;" line64="            case Button.Button6: pin = DigitalPin.P2; break;" line65="            case Button.Button7: pin = DigitalPin.P19; break;" line66="            case Button.Button8: pin = DigitalPin.P14; break;" line67="            case Button.Button9: pin = DigitalPin.P20; break;" line68="            case Button.Button10: pin = DigitalPin.P12; break;" line69="            case Button.Button11: pin = DigitalPin.P0; break;" line70="            case Button.Button12: pin = DigitalPin.P8; break;" line71="        }" line72="        return pin;" line73="    }" line74="" line75="    // inverted logic because of PullUp" line76="    //% block=&quot;not button $button is pressed&quot;" line77="    //% block.loc.nl=&quot;knop %button niet is ingedrukt&quot;" line78="    export function isButtonReleased(button: Button): boolean {" line79="        let pin2 = buttonPin(button);" line80="        if (pins.digitalReadPin(pin2) == 0)" line81="            return false;" line82="        return true;" line83="    }" line84="" line85="    // inverted logic because of PullUp" line86="    //% block=&quot;button $button is pressed&quot;" line87="    //% block.loc.nl=&quot;knop %button is ingedrukt&quot;" line88="    export function isButtonPressed(button: Button): boolean {" line89="        let pin3 = buttonPin(button);" line90="        if (pins.digitalReadPin(pin3) == 1)" line91="            return false;" line92="basic.showNumber(button)" line93="        return true;" line94="    }" line95="}" numlines="96"></mutation></block></statement></block></xml>